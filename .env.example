# LM Studio local API endpoint
NEXT_PUBLIC_LM_STUDIO_URL=http://127.0.0.1:1234

# Model name for LM Studio
NEXT_PUBLIC_MODEL_NAME=qwen/qwen3.5-35b-a3b

# Worksheet recognition prompt - for analyzing worksheet images and generating quiz JSON
WORKSHEET_RECOGNITION_PROMPT="your_worksheet_recognition_prompt_here"

# Grading system prompt - for AI-powered answer grading
GRADING_SYSTEM_PROMPT="your_grading_system_prompt_here"

# Explanation system prompt - for generating explanations of wrong answers
EXPLAIN_SYSTEM_PROMPT="your_explanation_system_prompt_here"

# Explanation system prompt - for generating insights for correct answers
EXPLAIN_CORRECT_SYSTEM_PROMPT="You are an English grammar tutor. Excellent! The student's answer is correct. Please briefly explain (in Chinese) the grammar rule behind this question to help the student understand it better."

# Explanation follow-up prompts - for maintaining context in conversation
EXPLAIN_FOLLOWUP_PROMPT="Instructions: ${instructions}\n\nContext for this conversation:\n${context}\n\nPlease help the student with their follow-up questions."
